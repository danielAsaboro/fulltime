{
  "name": "fulltime",
  "version": "0.1.0",
  "private": true,
  "description": "Spoiler-safe verified second-screen match rooms for the World Cup, powered by TxLINE.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=22.17.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "desktop": "npm --workspace @fulltime/desktop run start --",
    "desktop:dev": "npm --workspace @fulltime/desktop run start --",
    "desktop:local-config": "npm --workspace @fulltime/desktop run start:local-config",
    "desktop:replay": "npm --workspace @fulltime/desktop run start:replay-config",
    "desktop:package:web": "npm --workspace @fulltime/web run build && npm --workspace @fulltime/desktop run package:web",
    "desktop:package": "npm --workspace @fulltime/desktop run package",
    "desktop:smoke": "npm --workspace @fulltime/desktop run smoke",
    "desktop:smoke:public": "npm --workspace @fulltime/desktop run smoke:public",
    "desktop:test": "npm --workspace @fulltime/desktop run test",
    "desktop:test:integration": "npm --workspace @fulltime/desktop run test:integration",
    "test:slip:surfpool": "node --import tsx --test apps/web/test/slip-sdk-surfpool.integration.ts",
    "slip:play-runtime": "node apps/web/scripts/start-slip-play-runtime.mjs",
    "mobile:configure:local": "npm --workspace @fulltime/mobile run configure:local",
    "mobile:android": "npm --workspace @fulltime/mobile run android:local",
    "mobile:bundle:android": "npm --workspace @fulltime/mobile run bundle:android",
    "mobile:bundle:ios": "npm --workspace @fulltime/mobile run bundle:ios",
    "mobile:ios": "npm --workspace @fulltime/mobile run ios:device",
    "mobile:test": "npm --workspace @fulltime/mobile run test",
    "operator:publisher": "npm --workspace @fulltime/worker run operator:start",
    "operator:publisher:dev": "npm --workspace @fulltime/worker run operator:dev",
    "operator:local-config": "npm --workspace @fulltime/worker run operator:local-config",
    "operator:local-live": "npm --workspace @fulltime/worker run operator:local-live",
    "operator:replay": "npm --workspace @fulltime/worker run operator:replay",
    "operator:replay:start": "npm --workspace @fulltime/worker run operator:replay:start",
    "operator:manifest:sign": "npm --workspace @fulltime/worker run manifest:sign",
    "operator:manifest:verify": "npm --workspace @fulltime/worker run manifest:verify",
    "web:ui": "npm --workspace @fulltime/web run ui:dev",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "@solana/surfpool": "1.4.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@mutinylabs/slip": "^0.2.0",
    "@solana/kit": "^6.10.0",
    "@wallet-standard/app": "^1.1.0"
  }
}
