# FullTime environment — copy to .env and fill in. Never commit .env.

# --- Supabase (data + realtime) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- TxLINE feed origins ---
# Mainnet carries realtime (service level 12); devnet is for level-1 testing.
TXLINE_MAINNET_ORIGIN=https://txline.txodds.com
TXLINE_DEVNET_ORIGIN=https://txline-dev.txodds.com

# Which network the worker targets by default: devnet | mainnet
TXLINE_NET=devnet

# --- TxLINE access: fast path (recommended for the demo) ---
# If you already have tokens (affiliate site / prior activation), drop them here
# and the worker streams immediately, skipping on-chain activation.
TXLINE_JWT=
TXLINE_API_TOKEN=

# --- TxLINE access: activation path (when no API token is seeded) ---
# Run the on-chain subscribe(serviceLevel, weeks) with a funded wallet first, then:
ACTIVATION_KEYPAIR_PATH=          # solana-keygen JSON byte array, or base58 secret
ACTIVATION_TX_SIG=                # confirmed txSig of the on-chain subscribe
TXLINE_LEAGUES=                   # comma-separated league ids, e.g. 501,804
TXLINE_SERVICE_LEVEL=1            # 1 = 60s-delayed (devnet), 12 = realtime (mainnet)

# Optional: filter the fixtures snapshot to the World Cup competition id.
WORLDCUP_COMPETITION_ID=

# --- Worker runtime (optional; sensible defaults in code) ---
# LOG_LEVEL=info
# CORPUS_DIR=corpus
