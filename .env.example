# FullTime operator deployment configuration only.
#
# Desktop users do not copy this file and never provide TxLINE credentials,
# fixture-feed keys, manifest signing keys, or gateway secrets. See
# docs/operator-deployment.md for the deployment sequence and key rotation.

# --- TxLINE publisher credentials (operator secret storage) ---
TXLINE_NET=mainnet
# Optional selected-network alias; when set it overrides the matching origin.
TXLINE_BASE_URL=
TXLINE_MAINNET_ORIGIN=https://txline.txodds.com
TXLINE_DEVNET_ORIGIN=https://txline-dev.txodds.com
TXLINE_JWT=
TXLINE_API_TOKEN=
ACTIVATION_KEYPAIR_PATH=
ACTIVATION_TX_SIG=
TXLINE_LEAGUES=
TXLINE_SERVICE_LEVEL=12
TXLINE_DEFAULT_FIXTURE_ID=
WORLDCUP_COMPETITION_ID=
FIXTURE_PLANE_DIR=/var/lib/fulltime/fixture-plane
CORPUS_DIR=/var/lib/fulltime/corpus

# --- Signed public network manifest (operator-only) ---
# Ed25519 private key and TLS material must be injected from protected secret
# storage; do not commit them or ship them with the desktop app.
FULLTIME_MANIFEST_SIGNING_KEY_PATH=/run/secrets/fulltime-manifest-ed25519.pem
FULLTIME_MANIFEST_TLS_CERT_PATH=/run/secrets/fulltime-manifest-cert.pem
FULLTIME_MANIFEST_TLS_KEY_PATH=/run/secrets/fulltime-manifest-tls-key.pem
FULLTIME_MANIFEST_HOST=0.0.0.0
FULLTIME_MANIFEST_PORT=443
FULLTIME_MANIFEST_PATH=/v1/network.json
FULLTIME_MANIFEST_PUBLIC_URL=https://config.example.com/v1/network.json

# Optional authoritative answer and receipt pins. Set both or neither.
FULLTIME_ANSWER_ATTESTOR_PUBLIC_KEY=
FULLTIME_ANSWER_RECEIPT_FEED_KEY=

# Optional future external anchor observer pin. Set both or neither.
FULLTIME_ANCHOR_OBSERVER_PUBLIC_KEY=
FULLTIME_ANCHOR_OBSERVER_ENDPOINT=
